{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "outDir": "dist",
        "esModuleInterop": true,
        "moduleResolution": "Node",
        "sourceMap": true,
        "baseUrl": ".",
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"],
    "ts-node": {
        "esm": true,
        "transpileOnly": true,
        "files": true,
        "experimentalSpecifierResolution": "node"
    }
}
